            </xs:annotation>
          </xs:attribute>
          <xs:attribute name="lengthOut" type="xs:double" use="required">
            <xs:annotation>
              <xs:documentation>Curve lenght</xs:documentation>
            </xs:annotation>
          </xs:attribute>
          <xs:attribute name="desc" type="xs:string">
            <xs:annotation>
              <xs:documentation>Description</xs:documentation>
            </xs:annotation>
          </xs:attribute>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <xs:element name="CircCurve">
    <xs:annotation>
      <xs:documentation>A  Point of Vertical Intersection with a space delimited "station elevation" text value</xs:documentation>
