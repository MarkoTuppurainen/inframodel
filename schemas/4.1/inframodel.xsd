                          <xs:attribute name="label" type="InframodelParcelCoordGeomFeatureLabelUnionType" use="required"/>
                          <xs:attribute name="value" type="xs:string" use="required"/>
                        </xs:complexType>
                      </xs:element>
                    </xs:sequence>
                    <xs:attribute name="name" type="xs:string"/>
                    <xs:attribute name="code" type="InframodelParcelCoordGeomFeatureCodesType" use="required"/>
                    <xs:attribute name="source" use="required" fixed="inframodel"/>
                  </xs:complexType>
                </xs:element>
              </xs:sequence>
              <xs:attribute name="name" type="nameType">
                <xs:annotation>
                  <xs:documentation>Unique name</xs:documentation>
                </xs:annotation>
              </xs:attribute>
              <xs:attribute name="desc" type="xs:string">
                <xs:annotation>
                  <xs:documentation>Description</xs:documentation>
                </xs:annotation>
              </xs:attribute>
              <xs:attribute name="state" type="stateType">
                <xs:annotation>
                  <xs:documentation>State</xs:documentation>
                </xs:annotation>
              </xs:attribute>
            </xs:complexType>
          </xs:element>
        </xs:choice>
        <xs:element name="Feature" minOccurs="0" maxOccurs="unbounded">
          <xs:complexType>
            <xs:sequence>
              <xs:element name="Property" minOccurs="0" maxOccurs="7">
                <xs:complexType>
                  <xs:attribute name="label" type="InframodelParcelFeatureLabelUnionType" use="required"/>
                  <xs:attribute name="value" type="xs:string" use="required"/>
                </xs:complexType>
              </xs:element>
            </xs:sequence>
            <xs:attribute name="name" type="xs:string"/>
            <xs:attribute name="code" type="InframodelParcelFeatureCodesType" use="required"/>
            <xs:attribute name="source" use="required" fixed="inframodel"/>
          </xs:complexType>
        </xs:element>
      </xs:sequence>
      <xs:attribute name="name" type="nameType" use="required"/>
      <xs:attribute name="oID" type="xs:string"/>
      <xs:attribute name="area" type="xs:double"/>
      <xs:attribute name="desc" type="xs:string"/>
      <xs:attribute name="dirClosure" type="direction"/>
      <xs:attribute name="distClosure" type="xs:double"/>
      <xs:attribute name="owner" type="xs:string"/>
      <xs:attribute name="parcelType" type="xs:string"/>
      <xs:attribute name="state" type="parcelStateType"/>
    </xs:complexType>
  </xs:element>
  <xs:element name="Alignments">
    <xs:annotation>
      <xs:documentation>
Inframodel

A collection of horizontal Alignments</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="Alignment" maxOccurs="unbounded"/>
        <xs:element name="Feature" minOccurs="0" maxOccurs="unbounded">
          <xs:complexType>
            <xs:sequence>
              <xs:element name="Property" minOccurs="0" maxOccurs="6">
                <xs:complexType>
                  <xs:attribute name="label" type="InframodelAlignmentsFeatureLabelUnionType" use="required"/>
                  <xs:attribute name="value" type="xs:string" use="required"/>
                </xs:complexType>
              </xs:element>
              <xs:element name="Feature" minOccurs="0" maxOccurs="unbounded">
                <xs:complexType>
                  <xs:sequence>
                    <xs:element name="Property" minOccurs="3" maxOccurs="4">
                      <xs:complexType>
                        <xs:attribute name="label" type="InframodelIM_stringlineLayersFeatureLabelUnionType" use="required"/>
                        <xs:attribute name="value" type="xs:string" use="required"/>
                      </xs:complexType>
                    </xs:element>
                    <xs:element name="Feature" minOccurs="0" maxOccurs="unbounded">
                      <xs:complexType>
                        <xs:sequence>
                          <xs:element name="Property" minOccurs="0" maxOccurs="6">
                            <xs:complexType>
                              <xs:attribute name="label" type="InframodelIM_stringlineLayerFeatureLabelUnionType" use="required"/>
                              <xs:attribute name="value" type="xs:string" use="required"/>
                            </xs:complexType>
